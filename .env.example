# ── Backend environment ───────────────────────────────────────────────────────
# Copy to .env (local) or set these in the Railway dashboard. Never commit secrets.

# Postgres connection (Railway/Supabase provides this). Leave EMPTY in local dev to
# use the in-process Postgres fallback (PGlite) so the server runs without a DB.
DATABASE_URL=postgresql://user:pass@host:5432/solharvest

JWT_SECRET=change-me-to-a-long-random-string
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Comma-separated wallet addresses that get the admin role
ADMIN_WALLETS=

# ── Solana (switch devnet ↔ mainnet here — no code changes) ───────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
HARVEST_MINT=YvAwt42QVQ7jfArJsiwjZ6Gmu19UsaRWSPRBRZoGguG

# ── Pool wallet (custodial) ───────────────────────────────────────────────────
# Players send $HARVEST here (deposits); the backend sends $HARVEST from here
# (withdrawals). The PRIVATE KEY can move the whole pool — keep it secret.
POOL_WALLET_ADDRESS=PASTE_POOL_WALLET_PUBLIC_KEY
POOL_WALLET_PRIVATE_KEY=PASTE_POOL_WALLET_BASE58_SECRET

# ── Economy + anti-abuse limits ───────────────────────────────────────────────
TOKEN_TO_HC_RATE=1000
DEPOSIT_TAX=0.05
WITHDRAW_TAX=0.10
MIN_DEPOSIT_TOKENS=1000
MIN_WITHDRAW_HC=10
MAX_WITHDRAW_PER_DAY_HC=10000
MAX_WITHDRAWS_PER_HOUR=3
